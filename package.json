{
  "name": "astro-cloudfront-example",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "lint-fix": "pnpm -r --if-present --parallel /^.*-fix$/",
    "lint": "pnpm -r --if-present --parallel /^.*-check$/",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present --parallel test"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.7.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^24.16.0",
      "onFail": "download"
    }
  }
}
